generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  PANDADOC
  QUICKBOOKS
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum InvoiceStatus {
  PAID
  OVERDUE
  OPEN
  PARTIALLY_PAID
}

enum SyncTrigger {
  USER
  CRON
  SYSTEM
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum SyncDirection {
  PULL
  PUSH
  BIDIRECTIONAL
}

enum AuthIdentityProvider {
  GOOGLE
}

enum MarketplaceNode {
  PANDADOC
}

enum AccountingSystem {
  QUICKBOOKS
}

enum FactoringEligibilityStatus {
  ELIGIBLE
  INELIGIBLE
}

enum SettlementMethod {
  USDC_WALLET
  ACH
  DEBIT_CARD
}

enum FactoringTransactionStatus {
  PENDING
  FUNDED
  REPAID
  CANCELLED
}

enum CapitalSourceType {
  ARENA_STAFI_MANAGED_POOL
}

enum OnChainExecutionStatus {
  NOT_STARTED
  SIMULATED
  SETTLED
}

enum FactoringEventType {
  OFFER_GENERATED
  TERMS_ACCEPTED
  TRANSACTION_CREATED
  ARENA_SETTLEMENT_PREPARED
  STATUS_CHANGED
  REPAYMENT_RECORDED
}

model User {
  id             String                  @id @default(cuid())
  email          String                  @unique
  name           String?
  passwordHash   String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  sessions       AppSession[]
  oauthStates    OAuthState[]
  authIdentities UserIdentity[]
  connections    IntegrationConnection[]
  invoices       ImportedInvoice[]
  webhookEvents  WebhookEventLog[]
  syncRuns       SyncRun[]
  documentLinks  DocumentInvoiceLink[]
  factoringOffers FactoringOffer[]
  factoringTransactions FactoringTransaction[]
  factoringEvents FactoringEventLog[]
}

model AppSession {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OAuthState {
  id          String    @id @default(cuid())
  userId      String
  provider    Provider
  state       String    @unique
  redirectTo  String?
  codeVerifier String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([expiresAt])
}

model AuthLoginState {
  id         String               @id @default(cuid())
  provider   AuthIdentityProvider
  state      String               @unique
  redirectTo String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime             @default(now())

  @@index([provider, expiresAt])
}

model UserIdentity {
  id             String               @id @default(cuid())
  userId         String
  provider       AuthIdentityProvider
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  profile        Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model IntegrationConnection {
  id                  String                  @id @default(cuid())
  userId              String
  provider            Provider
  status              IntegrationStatus       @default(DISCONNECTED)
  displayName         String?
  externalAccountId   String?
  externalAccountName String?
  scopes              String[]
  lastSyncAt          DateTime?
  lastError           String?
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token               OAuthToken?
  quickBooksCompany   QuickBooksCompany?
  importedInvoices    ImportedInvoice[]
  webhookEvents       WebhookEventLog[]
  syncRuns            SyncRun[]
  documentLinks       DocumentInvoiceLink[]   @relation("PandaDocDocumentLinks")

  @@unique([userId, provider])
  @@index([provider, status])
}

model OAuthToken {
  id                     String   @id @default(cuid())
  connectionId           String   @unique
  accessTokenEncrypted   String
  refreshTokenEncrypted  String
  accessTokenExpiresAt   DateTime
  refreshTokenExpiresAt  DateTime?
  tokenType              String
  scope                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  connection             IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([accessTokenExpiresAt])
}

model QuickBooksCompany {
  id          String   @id @default(cuid())
  connectionId String  @unique
  realmId     String   @unique
  companyName String?
  country     String?
  currency    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  connection  IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  invoices    ImportedInvoice[]
}

model ImportedInvoice {
  id                 String        @id @default(cuid())
  userId             String
  connectionId       String
  quickBooksCompanyId String?
  provider           Provider
  providerInvoiceId  String
  docNumber          String?
  totalAmount        Decimal       @db.Decimal(18, 2)
  balanceAmount      Decimal       @db.Decimal(18, 2)
  currency           String?
  dueDate            DateTime?
  issueDate          DateTime?
  txnDate            DateTime?
  createdTime        DateTime?
  updatedTime        DateTime?
  counterpartyName   String
  counterpartyEmail  String?
  normalizedStatus   InvoiceStatus
  rawPayload         Json
  lastSyncedAt       DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection         IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  quickBooksCompany  QuickBooksCompany? @relation(fields: [quickBooksCompanyId], references: [id], onDelete: SetNull)
  documentLinks      DocumentInvoiceLink[]
  factoringOffer     FactoringOffer?
  factoringTransactions FactoringTransaction[]
  factoringEvents    FactoringEventLog[]

  @@unique([connectionId, providerInvoiceId])
  @@index([userId, normalizedStatus])
  @@index([connectionId, lastSyncedAt])
  @@index([counterpartyName])
}

model WebhookEventLog {
  id                 String   @id @default(cuid())
  provider           Provider
  userId             String?
  connectionId       String?
  externalEventId    String?
  eventType          String?
  signatureValidated Boolean?
  deliveryKey        String?
  payloadHash        String
  headers            Json
  payload            Json
  processedAt        DateTime?
  createdAt          DateTime @default(now())
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  connection         IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, payloadHash])
  @@index([provider, createdAt])
}

model SyncRun {
  id             String        @id @default(cuid())
  userId         String?
  connectionId   String?
  provider       Provider
  trigger        SyncTrigger
  status         SyncRunStatus
  fetchedCount   Int           @default(0)
  processedCount Int           @default(0)
  upsertedCount  Int           @default(0)
  skippedCount   Int           @default(0)
  errorCount     Int           @default(0)
  cursor         String?
  errorMessage   String?
  metrics        Json?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  connection     IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([provider, startedAt])
}

model MetricCounter {
  id         String   @id @default(cuid())
  name       String
  scope      String
  count      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, scope])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  keyHash     String
  bucketStart DateTime
  expiresAt   DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([keyHash, bucketStart])
  @@index([expiresAt])
}

model DocumentInvoiceLink {
  id                    String        @id @default(cuid())
  userId                String
  importedInvoiceId     String
  pandadocConnectionId  String?
  pandadocDocumentId    String
  documentName          String?
  pandadocDocumentStatus String?
  autoSend              Boolean       @default(false)
  sentAt                DateTime?
  lastSyncedAt          DateTime?
  lastError             String?
  syncDirection         SyncDirection @default(BIDIRECTIONAL)
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedInvoice       ImportedInvoice @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  pandadocConnection    IntegrationConnection? @relation("PandaDocDocumentLinks", fields: [pandadocConnectionId], references: [id], onDelete: SetNull)

  @@unique([userId, pandadocDocumentId])
  @@unique([userId, importedInvoiceId])
}

model CapitalSource {
  id                String           @id @default(cuid())
  key               String           @unique
  name              String
  marketplaceNode   MarketplaceNode
  type              CapitalSourceType
  network           String
  currency          String
  operatorWallet    String?
  liquiditySnapshot Decimal?         @db.Decimal(18, 2)
  isActive          Boolean          @default(true)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  offers            FactoringOffer[]
  transactions      FactoringTransaction[]

  @@index([marketplaceNode, type, isActive])
}

model FactoringOffer {
  id                   String                     @id @default(cuid())
  userId               String
  importedInvoiceId    String                     @unique
  capitalSourceId      String
  marketplaceNode      MarketplaceNode
  accountingSystem     AccountingSystem
  eligibilityStatus    FactoringEligibilityStatus
  ineligibilityReason  String?
  grossAmount          Decimal                    @db.Decimal(18, 2)
  discountRateBps      Int
  discountAmount       Decimal                    @db.Decimal(18, 2)
  netProceeds          Decimal                    @db.Decimal(18, 2)
  settlementCurrency   String
  settlementTimeSummary String
  termsSnapshot        Json
  generatedAt          DateTime                   @default(now())
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedInvoice      ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  capitalSource        CapitalSource              @relation(fields: [capitalSourceId], references: [id], onDelete: Restrict)
  transactions         FactoringTransaction[]

  @@index([userId, eligibilityStatus])
}

model FactoringTransaction {
  id                         String                     @id @default(cuid())
  transactionReference       String                     @unique
  userId                     String
  importedInvoiceId          String
  factoringOfferId           String?
  capitalSourceId            String
  marketplaceNode            MarketplaceNode
  accountingSystem           AccountingSystem
  status                     FactoringTransactionStatus @default(PENDING)
  settlementMethod           SettlementMethod
  settlementDestinationMasked String
  sellerWalletAddress        String?
  invoiceCurrency            String?
  settlementCurrency         String
  grossAmount                Decimal                    @db.Decimal(18, 2)
  discountRateBps            Int
  discountAmount             Decimal                    @db.Decimal(18, 2)
  netProceeds                Decimal                    @db.Decimal(18, 2)
  settlementTimeLabel        String
  termsAcceptedAt            DateTime
  fundedAt                   DateTime?
  repaidAt                   DateTime?
  operatorWallet             String?
  arenaSettlementReference   String?
  onChainExecutionStatus     OnChainExecutionStatus     @default(NOT_STARTED)
  metadata                   Json?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedInvoice            ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  factoringOffer             FactoringOffer?            @relation(fields: [factoringOfferId], references: [id], onDelete: SetNull)
  capitalSource              CapitalSource              @relation(fields: [capitalSourceId], references: [id], onDelete: Restrict)
  events                     FactoringEventLog[]

  @@index([userId, status, createdAt])
  @@index([importedInvoiceId, status])
}

model FactoringEventLog {
  id                    String                     @id @default(cuid())
  userId                String
  importedInvoiceId     String
  factoringTransactionId String?
  eventType             FactoringEventType
  statusFrom            FactoringTransactionStatus?
  statusTo              FactoringTransactionStatus?
  message               String
  metadata              Json?
  createdAt             DateTime                   @default(now())
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedInvoice       ImportedInvoice            @relation(fields: [importedInvoiceId], references: [id], onDelete: Cascade)
  factoringTransaction  FactoringTransaction?      @relation(fields: [factoringTransactionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([factoringTransactionId, createdAt])
}
